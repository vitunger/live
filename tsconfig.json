{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@core/*": ["portal/core/*"],
      "@views/*": ["portal/views/*"],
      "@inline/*": ["portal/inline/*"],
      "@types/*": ["portal/types/*"]
    }
  },
  "include": [
    "portal/types/**/*.d.ts",
    "portal/**/*.js",
    "portal/**/*.jsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "sw.js"
  ]
}
